{
  "name": "sexy-terminal-panel-cursor",
  "displayName": "Sexy Terminal Panel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/extension.js",
  "extensionKind": [
    "ui"
  ],
  "files": [
    "dist"
  ],
  "engines": {
    "vscode": "^1.105.0"
  },
  "activationEvents": [
    "onTerminalProfile:stp.tmuxTerminal",
    "onView:stp.terminals",
    "onCommand:stp.newTerminal",
    "onCommand:stp.showTerminal",
    "onCommand:stp.terminateCurrentTerminal"
  ],
  "contributes": {
    "commands": [
      {
        "command": "stp.newTerminal",
        "title": "New STP Terminal",
        "category": "STP"
      },
      {
        "command": "stp.showTerminal",
        "title": "Show STP Terminal",
        "category": "STP"
      },
      {
        "command": "stp.terminateCurrentTerminal",
        "title": "Terminate Current Terminal",
        "category": "STP"
      }
    ],
    "keybindings": [
      {
        "command": "stp.terminateCurrentTerminal",
        "key": "cmd+shift+backspace",
        "mac": "cmd+shift+backspace",
        "when": "terminalFocus"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "stp.showTerminal",
          "when": "false"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "stp.terminals",
          "name": "STP Terminals"
        }
      ]
    },
    "terminal": {
      "profiles": [
        {
          "id": "stp.tmuxTerminal",
          "title": "STP: tmux"
        }
      ]
    },
    "configurationDefaults": {
      "terminal.integrated.defaultProfile.osx": "STP: tmux"
    },
    "configuration": {
      "title": "Sexy Terminal Panel",
      "properties": {
        "stp.binaryPath": {
          "type": "string",
          "scope": "machine",
          "default": "stp",
          "description": "Path to the stp binary."
        },
        "stp.tmuxSocket": {
          "type": "string",
          "scope": "machine",
          "default": "stp-managed",
          "description": "tmux socket name used for STP terminal sessions."
        },
        "stp.registryPath": {
          "type": "string",
          "scope": "machine",
          "default": "",
          "description": "Path to the STP registry JSON file. Empty uses the default XDG state path."
        }
      }
    }
  },
  "scripts": {
    "compile": "bun build ./src/extension.ts --target=node --external vscode --format=esm --outdir dist",
    "package-vsix": "vsce package",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "bun run compile"
  },
  "devDependencies": {
    "@vscode/vsce": "3.9.2",
    "@types/bun": "^1.3.4",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.105.0",
    "typescript": "^5.9.3"
  }
}
